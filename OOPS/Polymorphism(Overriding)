class Behaviour
{
    void action()
    {
        System.out.println("Action performed");
    }
}

class Person1 extends Behaviour
{
    @Override
    void action()
    {
        System.out.println("Action is rude");
    }
}

class Person2 extends Behaviour
{
    @Override
    void action()
    {
        System.out.println("Action is Funny");
    }
}

public class Main
{
    public static void main(String[] args)
    {
        Behaviour p1 = new Person1();
        p1.action();

        Behaviour p2 = new Person2();
        p2.action();
    }
}
